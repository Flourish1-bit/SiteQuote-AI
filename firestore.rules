rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if true;
    }
    
    match /leads/{leadId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true;
    }
    
    match /proposals/{proposalId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true;
    }
  }
}

